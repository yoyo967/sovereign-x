# Sovereign 2030 Monorepo Gitignore

# dependencies
**/node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
web/.next/
web/out/

# production
/build

# misc
.DS_Store
*.pem
*.log
.firebase/
.vercel

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env*
.env.local
.env.*.local

# typescript
*.tsbuildinfo
next-env.d.ts

# backend (python)
backend/venv/
backend/__pycache__/
backend/*.pyc
backend/*.pyo
backend/*.pyd
backend/.pytest_cache/
backend/.coverage
backend/htmlcov/
backend/.mypy_cache/
backend/.dockerignore

# GCP / Firebase
.firebaserc
firebase-debug.log
firestore-debug.log
ui-debug.log
