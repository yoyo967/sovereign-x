{
  "firestore": {
    "rules": "firestore.rules"
  },
  "hosting": {
    "target": "sovereign-landing",
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "cleanUrls": true,
    "trailingSlash": false,
    "rewrites": [
      {
        "source": "**",
        "run": {
          "serviceId": "sovereign-web",
          "region": "europe-west4"
        }
      }
    ]
  }
}
